# Required: judge LLM for scoring responses (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# For OpenRouter-hosted models
OPENROUTER_API_KEY=sk-or-...

# For standard OpenAI models
# OPENAI_API_KEY=sk-...

# Baseline model — responses stored in baseline/ become the reference
BENCH_BASELINE_MODEL=anthropic:claude-sonnet-4-6

# Judge model — evaluates how close a test run is to the baseline
BENCH_JUDGE_MODEL=claude-sonnet-4-6

# Local model backends (ollama / lmstudio)
# LOCAL_MODEL_READ_TIMEOUT=600
# CONDOR_DEFAULT_LOCAL_MODEL=llama3.1:8b
